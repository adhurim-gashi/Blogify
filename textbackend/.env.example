# PostgreSQL connection
DATABASE_URL=postgresql://user:password@localhost:5432/blogify?schema=public

# Server
PORT=4000

# JWT secrets
JWT_ACCESS_SECRET=replace-with-secure-random
JWT_REFRESH_SECRET=replace-with-secure-random
JWT_ACCESS_EXP=15m
JWT_REFRESH_EXP=7d

# Seed admin
SEED_ADMIN_EMAIL=admin@blogify.local
SEED_ADMIN_PASSWORD=change_me

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Max upload file size in bytes (default 5MB)
MAX_UPLOAD_SIZE=5242880
DATABASE_URL="postgresql://user:password@localhost:5432/blogify?schema=public"
PORT=4000
JWT_ACCESS_SECRET=replace-with-secure-random
JWT_REFRESH_SECRET=replace-with-secure-random
JWT_ACCESS_EXP=15m
JWT_REFRESH_EXP=7d
SEED_ADMIN_EMAIL=admin@blogify.local
SEED_ADMIN_PASSWORD=password123
