{
  "name": "blogify-backend",
  "version": "1.0.0",
  "description": "Backend for Blogify - Express + Prisma + PostgreSQL",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js --watch src --ext js",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "seed": "node prisma/seed.js"
  },
  "engines": {
    "node": ">=16"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "helmet": "^6.0.1",
    "sanitize-html": "^2.11.1",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "prisma": "^5.10.1",
    "slugify": "^1.6.6",
    "zod": "^3.23.2",
    "@prisma/client": "^5.10.1"
  },
  "devDependencies": {
    "nodemon": "^2.0.22"
  }
}
